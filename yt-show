def load_state():
    try:
        with open(STATE_PATH, encoding="utf-8") as f:
            data = json.load(f)
        if isinstance(data, dict):
            data.setdefault("version", 1)
            data.setdefault("shows", {})
            return data
    except (OSError, ValueError):
        pass
    return {"version": 1, "shows": {}}


def save_state(state):
    tmp = STATE_PATH + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(state, f, indent=2)
    os.replace(tmp, STATE_PATH)


def acquire_show_lock(slug):
    """Take an exclusive, advisory per-show lock so two yt-show runs for the
    SAME show can't race each other's state writes and staging (concurrent
    save_state clobbers a commit; both upload the same episode). Returns the
    open lock file (KEEP IT ALIVE to hold the lock) or None if another live run
    already holds it. flock is released automatically when this process exits or
    is killed, so there is no stale lock file to clean up. Different shows use
    different lock files, so they never block each other."""
    path = os.path.join(renamer._default_support_dir(), ".yt-show-%s.lock" % slug)
    fd = open(path, "w")
    try:
        fcntl.flock(fd.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:               # another run holds it (EWOULDBLOCK / EACCES)
        fd.close()
        return None
    try:
        fd.write("%d\n" % os.getpid())
        fd.flush()
    except OSError:
        pass
    return fd


