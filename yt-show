def resolve_connstr(drive):
    """'todrive resolve --create' prints the rclone connstr (e.g.
    'gdrive,team_drive=<ID>:')."""
    r = subprocess.run([sys.executable, TODRIVE, "resolve", "--create", drive],
                       capture_output=True, text=True)
    dest = (r.stdout or "").strip()
    if r.returncode != 0 or not dest:
        sys.exit("could not resolve/create drive %r: %s" %
                 (drive, (r.stderr or "").strip()))
    return dest   # ends with ':'


def _human(n):
    """DECIMAL sizes to match todrive/Drivecast's 100 GB cap accounting."""
    n = float(n)
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if abs(n) < 1000.0:
            return "%.1f %s" % (n, unit)
        n /= 1000.0
    return "%.1f PB" % n


def parse_drive_usage(data):
    """Turn a 'todrive du --json' payload into {name: {used,cap,free,pct}}.
    'used' and 'free' count trash against the cap (trashed files still occupy a
    Shared Drive), matching storage_monitor.py's FREE/TOTAL columns. Pure."""
    cap = data.get("cap_bytes") or 0
    out = {}
    for d in (data.get("drives") or []):
        name = d.get("name") or ""
        if not name:
            continue
        used = (d.get("bytes", 0) or 0) + (d.get("trash_bytes", 0) or 0)
        out[name] = {
            "used": used, "cap": cap,
            "free": (max(0, cap - used) if cap else None),
            "pct": (round(used / cap * 100, 1) if cap else None),
        }
    return out


def fetch_drive_usage():
    """Live per-drive usage via 'todrive du --json' (read-only files.list GETs,
    fresher than the GUI's 5-min cache). Best-effort: returns {} on any error so
    it never blocks the actual download/upload."""
    try:
        r = subprocess.run([sys.executable, TODRIVE, "du", "--json"],
                           capture_output=True, text=True, timeout=120)
        if r.returncode != 0 or not r.stdout.strip():
            return {}
        return parse_drive_usage(json.loads(r.stdout))
    except Exception:
        return {}


def drive_storage_line(drive, usage=None):
    """One-line live headroom for a drive, or None if usage is unknown (e.g. a
    brand-new drive not yet created)."""
    u = (usage if usage is not None else fetch_drive_usage()).get(drive)
    if not u or u["free"] is None:
        return None
    return "drive %r: %s used · %s free of %s (%.0f%% full)" % (
        drive, _human(u["used"]), _human(u["free"]), _human(u["cap"]), u["pct"])


def pick_drive():
    """--pick: list Shared Drives, let the user choose one or type a NEW name
    to create."""
    names = []
    r = subprocess.run([sys.executable, TODRIVE, "list", "--json"],
                       capture_output=True, text=True)
    if r.returncode == 0 and r.stdout.strip():
        try:
            names = [d.get("name") for d in json.loads(r.stdout) if d.get("name")]
        except ValueError:
            names = []
    if not names:   # fallback: parse the plain table (skip NAME header + summary)
        r2 = subprocess.run([sys.executable, TODRIVE, "list"],
                            capture_output=True, text=True)
        for ln in (r2.stdout or "").splitlines():
            s = ln.strip()
            if s and not s.startswith("NAME") and "shared drive" not in s:
                names.append(s.split("  ")[0].strip())
    usage = fetch_drive_usage()   # live headroom per drive (best-effort)
    print("Shared drives:")
    for i, n in enumerate(names, 1):
        u = usage.get(n)
        if u and u["free"] is not None:
            print("  %d) %-24s %s free · %.0f%% full" %
                 (i, n, _human(u["free"]), u["pct"]))
        else:
            print("  %d) %s" % (i, n))
    print("  (enter a number, or type a NEW drive name to create it)")
    choice = input("drive> ").strip()
    if choice.isdigit() and 1 <= int(choice) <= len(names):
        return names[int(choice) - 1]
    if not choice:
        sys.exit("no drive selected")
    return choice


# ===========================================================================
# Live terminal dashboard (rich, with a plain-text fallback)
# ===========================================================================

# state -> (glyph, rich style). Cyan download / magenta upload mirror the two
# concurrent progress bars.
_GLYPH = {
    "done": ("✔", "green"),        # heavy check
    "downloading": ("⬇", "cyan"),  # down arrow
    "uploading": ("⬆", "magenta"), # up arrow
    "pending": ("○", "dim"),       # hollow circle
    "failed": ("✖", "red"),        # heavy multiplication x
}
_GLYPH_ORDER = ("done", "downloading", "uploading", "pending", "failed")
_BOARD_FULL_MAX = 40   # collapse the glyph row to counts beyond this many eps


def _bar(pct, width=12):
    """Fixed-width block-char progress bar (used by the capacity line and the
    plain-text download/upload progress)."""
    p = 0.0 if pct is None else max(0.0, min(100.0, float(pct)))
    filled = int(round(width * p / 100.0))
    return "█" * filled + "░" * (width - filled)


def _fmt_speed(speed):
    """Format a speed for the plain UI. yt-dlp hands us bytes/sec (a number);
    rclone hands us a ready-made string like '5.0 MiB/s' — pass either."""
    if not speed:
        return ""
    if isinstance(speed, str):
        return speed
    return _human(speed) + "/s"


class UI:
    """Owns the single rich Live (or the plain-text fallback) for the whole
    run. The lock guards the board/counters, which are mutated from BOTH the
    producer (download, main thread) and the consumer (upload, worker thread)
    and read by the Live refresh thread in render()."""

    def __init__(self, use_rich):
        # rich must actually be importable to honour use_rich; otherwise degrade
        # to plain so a caller passing use_rich=True can't hit a None progress.
        self.use_rich = bool(use_rich) and RichProgress is not None
        self.lock = threading.Lock()
        self.show = ""
        self.drive = ""
        self._free = None
        self._cap = None
        self._pct = None
        self.new_total = 0
        self.already = 0
        self.grand_total = 0
        self.episodes = []      # ordered [(season, episode)]
        self.ep_meta = {}       # (season, episode) -> plan dict
        self.ep_state = {}      # (season, episode) -> state str
        self._live = None       # the single RichLive (rich mode only)
        self.console = None
        self.dl_progress = None
        self.up_progress = None
        self.overall_progress = None
        self._dl_task = None
        self._up_task = None
        self._overall_task = None
        self._dl_label = ""
        self._up_label = ""
        self._plain_dl_last = 0.0
        self._plain_up_last = 0.0
        self._noted = set()
        if self.use_rich:
            self.console = RichConsole()
            self.dl_progress = self._make_progress()
            self.up_progress = self._make_progress()
            self.overall_progress = RichProgress(
                TextColumn("[bold]episodes[/bold]"),
                BarColumn(),
                TextColumn("{task.completed}/{task.total}"),
                console=self.console, transient=False,
            )

    def _make_progress(self):
        # Mirrors video-loop-extractor's download columns: spinner + label +
        # bar + size + transfer speed + ETA, used as a plain renderable inside
        # the one Live (never started on its own).
        return RichProgress(
            SpinnerColumn(),
            TextColumn("{task.description}"),
            BarColumn(),
            DownloadColumn(),
            TransferSpeedColumn(),
            TimeRemainingColumn(),
            console=self.console,
            transient=False,
        )

    # -- lifecycle -----------------------------------------------------------
    def start(self):
        if self.use_rich and RichLive is not None:
            self._live = RichLive(get_renderable=self.render,
                                  console=self.console, refresh_per_second=8)
            self._live.start()

    def stop(self):
        if self.use_rich and self._live is not None:
            try:
                self._live.stop()
            except Exception:
                pass
            self._live = None

    @contextlib.contextmanager
    def live(self):
        """`with ui.live(): ...` — the ONE Live for the whole pipeline. Never
        nested; any input()/prompt must happen before entering this."""
        self.start()
        try:
            yield self
        finally:
            self.stop()

    def note(self, text):
        """Print a one-off note once (deduped). In rich mode it prints above
        the Live region; otherwise a plain stderr line."""
        with self.lock:
            if text in self._noted:
                return
            self._noted.add(text)
        if self.use_rich and self._live is not None:
            try:
                self._live.console.print(text)
                return
            except Exception:
                pass
        sys.stderr.write(text + "\n")
        sys.stderr.flush()

    # -- header / capacity / counts -----------------------------------------
    def set_header(self, show, drive):
        with self.lock:
            self.show = show
            self.drive = drive
        if not self.use_rich:
            sys.stderr.write("yt-show · %s → %s\n" % (show, drive))
            sys.stderr.flush()

    def set_capacity(self, free_bytes, cap_bytes, pct):
        with self.lock:
            self._free = free_bytes
            self._cap = cap_bytes
            self._pct = pct
        if not self.use_rich:
            if free_bytes is None:
                sys.stderr.write("  capacity unknown\n")
            else:
                sys.stderr.write("  %s · %s free · %.0f%% full\n" %
                                 (self.drive, _human(free_bytes), pct or 0))
            sys.stderr.flush()

    def set_counts(self, new_total, already, grand_total):
        with self.lock:
            self.new_total = new_total
            self.already = already
            self.grand_total = grand_total
        if not self.use_rich:
            sys.stderr.write("  episodes: %d new, %d already, %d total\n" %
                             (new_total, already, grand_total))
            sys.stderr.flush()

    # -- episode board -------------------------------------------------------
    def register_episodes(self, items):
        with self.lock:
            self.episodes = [(it["season"], it["episode"]) for it in items]
            self.ep_meta = {(it["season"], it["episode"]): it for it in items}
            self.ep_state = {k: "pending" for k in self.episodes}
        if self.use_rich and self.overall_progress is not None:
            self._overall_task = self.overall_progress.add_task(
                "", total=max(1, len(self.episodes)))

    def update_status(self, key, state):
        with self.lock:
            if key in self.ep_state:
                self.ep_state[key] = state
            done = sum(1 for s in self.ep_state.values() if s == "done")
        if self.use_rich and self._overall_task is not None:
            try:
                self.overall_progress.update(self._overall_task, completed=done)
            except Exception:
                pass
        elif not self.use_rich and state == "failed":
            sys.stderr.write("  ✖ S%02dE%02d failed\n" % (key[0], key[1]))
            sys.stderr.flush()

    def _glyph_row_markup(self):
        # Caller holds self.lock.
        states = [self.ep_state.get(k, "pending") for k in self.episodes]
        if not states:
            return ""
        if len(states) <= _BOARD_FULL_MAX:
            out = []
            for s in states:
                g, style = _GLYPH[s]
                out.append("[%s]%s[/%s]" % (style, g, style))
            return "".join(out)
        # Too many to show one glyph each -> collapse to counts.
        from collections import Counter
        c = Counter(states)
        parts = []
        for st in _GLYPH_ORDER:
            if c.get(st):
                g, style = _GLYPH[st]
                parts.append("[%s]%s[/%s]×%d" % (style, g, style, c[st]))
        return " ".join(parts)

    # -- download progress ---------------------------------------------------
    def dl_start(self, label, total_bytes):
        with self.lock:
            self._dl_label = label
        if self.use_rich:
            self._dl_task = self.dl_progress.add_task(
                "⬇ %s" % label, total=total_bytes)
        else:
            self._plain_dl_last = 0.0
            sys.stderr.write("  ⬇ %s  0%%\r" % label)
            sys.stderr.flush()

    def dl_advance(self, done_bytes, total_bytes, speed):
        if self.use_rich:
            if self._dl_task is not None:
                kw = {"completed": done_bytes or 0}
                if total_bytes:
                    kw["total"] = total_bytes
                try:
                    self.dl_progress.update(self._dl_task, **kw)
                except Exception:
                    pass
        else:
            now = time.monotonic()
            if now - self._plain_dl_last < 1.0:
                return
            self._plain_dl_last = now
            pct = int(100 * done_bytes / total_bytes) if total_bytes else 0
            sys.stderr.write("  ⬇ %s  %d%%  %s\r" %
                             (self._dl_label, pct, _fmt_speed(speed)))
            sys.stderr.flush()

    def dl_finish(self):
        if self.use_rich:
            if self._dl_task is not None:
                try:
                    self.dl_progress.remove_task(self._dl_task)
                except Exception:
                    pass
                self._dl_task = None
        else:
            sys.stderr.write("\n")
            sys.stderr.flush()

    # -- upload progress -----------------------------------------------------
    def up_start(self, label, total_bytes):
        with self.lock:
            self._up_label = label
        if self.use_rich:
            self._up_task = self.up_progress.add_task(
                "⬆ %s" % label, total=total_bytes)
        else:
            self._plain_up_last = 0.0
            sys.stderr.write("  ⬆ %s  0%%\r" % label)
            sys.stderr.flush()

    def up_advance(self, done_bytes, total_bytes, speed):
        if self.use_rich:
            if self._up_task is not None:
                kw = {"completed": done_bytes or 0}
                if total_bytes:
                    kw["total"] = total_bytes
                try:
                    self.up_progress.update(self._up_task, **kw)
                except Exception:
                    pass
        else:
            now = time.monotonic()
            if now - self._plain_up_last < 1.0:
                return
            self._plain_up_last = now
            pct = int(100 * done_bytes / total_bytes) if total_bytes else 0
            sys.stderr.write("  ⬆ %s  %d%%  %s\r" %
                             (self._up_label, pct, _fmt_speed(speed)))
            sys.stderr.flush()

    def up_finish(self):
        if self.use_rich:
            if self._up_task is not None:
                try:
                    self.up_progress.remove_task(self._up_task)
                except Exception:
                    pass
                self._up_task = None
        else:
            sys.stderr.write("\n")
            sys.stderr.flush()

    # -- render (rich only; called by the Live refresh thread) --------------
    def render(self):
        with self.lock:
            title = "yt-show · %s → %s" % (self.show, self.drive)
            if self._free is None:
                cap = "capacity unknown"
            else:
                cap = "%s · %s free · %.0f%% full" % (
                    self.drive, _human(self._free), self._pct or 0)
        items = [RichText(title, style="bold"), RichText(cap, style="dim")]
        if self.overall_progress is not None and self.overall_progress.task_ids:
            items.append(self.overall_progress)
        if self.dl_progress is not None and self.dl_progress.task_ids:
            items.append(self.dl_progress)
        if self.up_progress is not None and self.up_progress.task_ids:
            items.append(self.up_progress)
        return RichGroup(*items)


# ===========================================================================
# Download (lazy yt_dlp; native concurrent fragments by default, aria2c
# multi-connection per video when --connections > 1 = Motrix-style)
# ===========================================================================

_STEM_FRAGMENT_RE = re.compile(r"\.f\d+\.")   # pre-merge stream, e.g. '.f137.'
_STEM_TEMP_RE = re.compile(r"\.temp\.")       # mid-merge, pre-os.rename


def staged_download_stem(out_stem_path, vid):
    """The ON-DISK stem download_one actually writes to and staged_complete_path
    reuse-checks against -- the canonical stem plus a ' [<video_id>]' tag.

    The canonical stem alone (season/episode/title) is NOT guaranteed unique
    to one video across runs (see the module docstring), so every staged
    artifact is bound to its video id here; the tag is stripped back off
    before the file ever reaches the drive (upload_worker computes the
    canonical, untagged dest name separately). One helper, shared by
    download_one and main()'s reuse check, so the tagging scheme can't drift
    between writer and reader."""
    return "%s [%s]" % (out_stem_path, vid)


def staged_complete_path(out_stem_path):
    """Return the path to a COMPLETE staged download for out_stem_path, or
    None if nothing complete is there. Shared by download_one's success path
    and main()'s crash-recovery skip -- one classifier, one wrong-file bug to
    fix.

    Completion is judged ONLY by name shape + marker siblings -- NEVER by
    size (a slowly-writing file must not be mistaken for complete). The
    invariant: yt-dlp renames a `.part` to its final name only on completion,
    and a merge lands via `<stem>.temp.mp4` + `os.rename` -- so a surviving
    final-shaped candidate (no partial marker, not a pre-merge stream, not a
    mid-rename temp file) IS complete.
    """
    candidates = glob.glob(glob.escape(out_stem_path) + ".*")
    survivors = []
    for p in candidates:
        base = os.path.basename(p)
        if p.endswith((".part", ".ytdl", ".aria2")):
            continue
        if _STEM_FRAGMENT_RE.search(base) or _STEM_TEMP_RE.search(base):
            continue
        # aria2c writes the REAL filename with only a '.aria2' sibling (no
        # '.part'), so check all three control suffixes as siblings too.
        if any(os.path.exists(p + sfx) for sfx in (".part", ".ytdl", ".aria2")):
            continue
        survivors.append(p)
    if not survivors:
        return None
    exact = out_stem_path + ".mp4"   # merge_output_format is hardcoded mp4
    if exact in survivors:
        return exact
    return max(survivors, key=os.path.getmtime)


def download_one(vid, out_stem_path, height, connections, on_progress=None):
    """Download one video to staged_download_stem(out_stem_path, vid) + real
    ext (NOT out_stem_path directly -- see that helper). Returns the produced
    file path, or None on failure. connections>1 -> aria2c external
    downloader (-x/-s N) if aria2c is on PATH, else native concurrent
    fragments. VIDEOS are downloaded sequentially by the caller; the
    parallelism is WITHIN each video (YouTube throttles per connection, so
    multi-connection is the speed win).

    Partial files resume via yt-dlp's own default (continuedl=True as of
    this writing) -- left unset deliberately, not passed explicitly."""
    import yt_dlp
    dl_stem = staged_download_stem(out_stem_path, vid)
    outtmpl = dl_stem.replace("%", "%%") + ".%(ext)s"
    if height:
        fmt = ("bestvideo[height<=%d]+bestaudio/best[height<=%d]/best" %
               (height, height))
    else:
        fmt = "bestvideo+bestaudio/best"
    opts = {"format": fmt, "outtmpl": outtmpl, "quiet": True, "no_warnings": True,
            "noplaylist": True, "merge_output_format": "mp4"}
    if connections and connections > 1 and shutil.which("aria2c"):
        opts["external_downloader"] = "aria2c"
        opts["external_downloader_args"] = {
            "aria2c": ["-x", str(connections), "-s", str(connections), "-k", "1M"]}
    else:
        opts["concurrent_fragment_downloads"] = 4
    if on_progress is not None:
        # Feed the live dashboard. quiet stays on so yt-dlp itself prints
        # nothing; the hook fires per stream (video, then audio) so byte totals
        # reset between streams -- coarse but fine for a progress bar. (The
        # aria2c branch's hooks are coarser still; accepted.)
        def _hook(d):
            tot = (d.get("total_bytes") or d.get("total_bytes_estimate") or 0)
            on_progress(d.get("status"), d.get("downloaded_bytes") or 0, tot,
                        d.get("speed") or 0)
        opts["progress_hooks"] = [_hook]
    url = "https://www.youtube.com/watch?v=" + vid
    try:
        with yt_dlp.YoutubeDL(opts) as ydl:
            ydl.download([url])
    except Exception as exc:
        sys.stderr.write("  ! download failed for %s: %s\n" % (vid, exc))
        # Do NOT delete stem.* here: every artifact under this stem is either
        # resumable state (.part/.ytdl/.aria2/.fNNN -- kept for continuedl's
        # default resume) or a complete final file, and a complete final must
        # never be wiped just because a later metadata fetch failed (e.g. the
        # source video went private after a fully-successful download).
        return None
    return staged_complete_path(dl_stem)


# ===========================================================================
# Upload leg -- per FILE, straight to the drive (mirrors stream-dl's
# rclone-to-connstr pattern)
# ===========================================================================

_UP_PCT_RE = re.compile(r"(\d+)%")
_UP_SPEED_RE = re.compile(r"[\d.]+\s*[KMGT]?i?B/s")


def upload_file(filepath, connstr, folder, dest_name, on_progress=None):
    """rclone moveto <file> <connstr><folder>/<dest_name> -- moves ONE finished
    file into the season folder on Drive and deletes it locally on success.
    (We cannot 'todrive up' a lone file: it would land at the drive ROOT, not
    inside '<Show> Season N/'.) Returns rclone's return code.

    dest_name is the CANONICAL leaf the caller computes (never derived from
    filepath's own basename): filepath's basename carries a ' [<video_id>]'
    staging tag (see staged_download_stem) that must never reach the drive.

    With on_progress, run rclone with live stats and stream them to the
    dashboard; total is the local file size, percent/speed come from rclone's
    one-line stats (which it refreshes with a carriage return)."""
    dest = connstr + folder + "/" + dest_name
    if on_progress is None:
        cmd = [RCLONE, "moveto", filepath, dest, "--drive-chunk-size", "128M"]
        return subprocess.run(cmd).returncode

    total = os.path.getsize(filepath) if os.path.exists(filepath) else 0
    # -v (not -P): piped, rclone's -P prints only the final line, but -v raises
    # the log level so the periodic --stats line prints every second (that is
    # what drives the live upload bar). Verified against rclone's piped output.
    cmd = [RCLONE, "moveto", filepath, dest, "--drive-chunk-size", "128M",
           "-v", "--stats=1s", "--stats-one-line"]
    proc = subprocess.Popen(cmd, stdout=subprocess.PIPE,
                            stderr=subprocess.STDOUT, text=True)
    buf = ""
    while True:
        ch = proc.stdout.read(1)
        if ch == "":
            break
        if ch in ("\r", "\n"):     # rclone refreshes its stats line via \r
            line, buf = buf.strip(), ""
            if line:
                m = _UP_PCT_RE.search(line)
                if m:
                    pct = int(m.group(1))
                    sm = _UP_SPEED_RE.search(line)
                    on_progress(int(total * pct / 100), total,
                                sm.group(0) if sm else "")
        else:
            buf += ch
    proc.wait()
    return proc.returncode


# ===========================================================================
# The pipeline -- producer (download, main thread) + consumer (upload, worker
# thread). A gap semaphore (--max-gap permits) caps how many episodes are
# downloaded-but-not-yet-uploaded: the producer acquires a permit before each
# download and the consumer releases one after each upload, so when max_gap
# episodes are pending the next download blocks until an upload drains. Overlap:
# while the producer downloads item N+1, the consumer uploads item N. STATE is
# written ONLY by the consumer thread (single writer) so no lock is needed; the
# producer never mutates show_rec. An episode is committed only after rclone rc==0.
#
# Re-uploading to the same canonical dest is idempotent (rclone moveto
# overwrites an existing dest file), so the one accepted crash window --
# rc==0 on the upload but killed before save_state commits it -- costs one
# redundant re-download-or-reuse-and-re-upload on the next run, NEVER a
# duplicate on the drive.
# ===========================================================================

def reconcile_stage(stage, display, show_rec, plan=None, ui_note=print):
    """Startup crash-recovery pass over one show's staging area. Pure enough
    to unit-test with a tmpdir: the only side effects are os.remove and a call
    to ui_note.

    Two jobs:
      1. A committed episode's stem is deterministic from its stored
         season/episode/title (synth_episode + canonical_episode_name). Since
         state commits only after rclone rc==0 -- and moveto already deleted
         the local file on that success -- any staged file STILL matching a
         committed stem is drift residue (e.g. a crash between upload and the
         end-of-run stage cleanup). Delete it.
      2. Anything else left in this show's season dirs, matching NEITHER a
         committed stem NOR a stem from the CURRENT plan (still-pending
         episodes -- a resumable partial, or a complete file the producer's
         staged_complete_path check will reuse directly), is unrecognized:
         print one warning line (count + example) and never delete it -- it
         could belong to a concurrent run, or another playlist for the same
         show.

    Each entry is matched by BOTH its bare canonical stem and its vid-tagged
    staged_download_stem form: real staged artifacts are always written under
    the tagged form (never the bare one, which is reserved for the eventual
    drive dest name -- see the module docstring), but the bare form is kept
    too so any leftover from before staged files were vid-tagged is still
    recognized. Matching the bare form here is safe (unlike in the producer's
    reuse check) since reconcile only deletes already-committed residue or
    warns -- it never reuses file content by name.
    """
    episodes = show_rec.get("episodes") or {}
    committed_stems = {}   # folder -> {stem, stem[vid], ...}
    for vid, rec in episodes.items():
        ep = renamer.synth_episode(display, rec["season"], rec["episode"],
                                   rec.get("title") or "")
        stem = renamer.canonical_episode_name(display, ep, "")
        folder = renamer.canonical_folder_name(display, rec["season"])
        committed_stems.setdefault(folder, set()).update(
            (stem, staged_download_stem(stem, vid)))

    plan_stems = {}
    for a in (plan or []):
        ep = renamer.synth_episode(display, a["season"], a["episode"], a["title"])
        stem = renamer.canonical_episode_name(display, ep, "")
        folder = renamer.canonical_folder_name(display, a["season"])
        plan_stems.setdefault(folder, set()).update(
            (stem, staged_download_stem(stem, a["vid"])))

    removed = 0
    for folder, stems in committed_stems.items():
        for stem in stems:
            for p in glob.glob(os.path.join(stage, folder, glob.escape(stem)) + ".*"):
                try:
                    os.remove(p)
                    removed += 1
                except OSError:
                    pass
    if removed:
        ui_note("reconcile: removed %d stale staged file(s) for "
                "already-uploaded episodes" % removed)

    leftover = []
    for folder in sorted(set(committed_stems) | set(plan_stems)):
        dirpath = os.path.join(stage, folder)
        if not os.path.isdir(dirpath):
            continue
        known = committed_stems.get(folder, set()) | plan_stems.get(folder, set())
        for name in os.listdir(dirpath):
            if any(name.startswith(stem + ".") for stem in known):
                continue
            leftover.append(os.path.join(folder, name))
    if leftover:
        ui_note("reconcile: %d leftover unrecognized file(s) in stage -- not "
                "touching them (e.g. %r)" % (len(leftover), leftover[0]))
    return removed


def upload_worker(q, connstr, display, plid, show_rec, state, results,
                  results_lock, ui, gap):
    while True:
        job = q.get()
        try:
            if job is None:
                return
            a, filepath = job
            key = (a["season"], a["episode"])
            # Guard the whole job: if this thread died (e.g. rclone missing ->
            # FileNotFoundError, or save_state -> OSError) the producer would
            # deadlock forever on the bounded queue. Stay alive, count the
            # failure, leave the file local for the next run to retry.
            try:
                folder = renamer.canonical_folder_name(display, a["season"])
                # Canonical, UNTAGGED dest name -- filepath's own basename
                # carries a ' [<video_id>]' staging tag (staged_download_stem)
                # that must never land on the drive.
                ep = renamer.synth_episode(display, a["season"], a["episode"],
                                           a["title"])
                ext = os.path.splitext(filepath)[1]
                dest_name = renamer.canonical_episode_name(display, ep, ext)
                label = "S%02dE%02d %s" % (a["season"], a["episode"], a["title"])
                ui.update_status(key, "uploading")
                try:
                    total = os.path.getsize(filepath)
                except OSError:
                    total = 0
                ui.up_start(label, total)
                rc = upload_file(filepath, connstr, folder, dest_name,
                                 on_progress=ui.up_advance)
                ui.up_finish()
                if rc == 0:
                    show_rec["episodes"][a["vid"]] = {
                        "season": a["season"], "episode": a["episode"], "playlist": plid,
                        "title": renamer.clean_source_title(a["title"], display),
                        "uploaded": datetime.date.today().isoformat()}
                    cur = show_rec["playlists"].get(plid, {}).get("season", 0)
                    show_rec["playlists"][plid] = {"season": max(cur, a["season"])}
                    save_state(state)
                    ui.update_status(key, "done")
                    with results_lock:
                        results["uploaded"] += 1
                else:
                    ui.update_status(key, "failed")
                    ui.note("  ! upload failed S%02dE%02d (rc=%d); left local %s"
                            % (a["season"], a["episode"], rc, filepath))
                    with results_lock:
                        results["failed"] += 1
            except Exception as exc:
                ui.up_finish()
                ui.update_status(key, "failed")
                ui.note("  ! upload worker error S%02dE%02d: %s"
                        % (a["season"], a["episode"], exc))
                with results_lock:
                    results["failed"] += 1
        finally:
            q.task_done()
            # Release the pending-upload slot so the producer can download the
            # next episode. NOT for the sentinel (it never took a slot).
            if job is not None:
                gap.release()


