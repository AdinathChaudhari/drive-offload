# CLI / main
# ===========================================================================

def build_parser():
    ap = argparse.ArgumentParser(
        prog="yt-show",
        description="Turn a YouTube playlist into a Drivecast TV show "
                    "(download + upload pipelined).")
    ap.add_argument("url", help="YouTube playlist URL")
    ap.add_argument("--show", default=None,
                    help="display show name (default: cleaned playlist title "
                         "on a brand-new show)")
    ap.add_argument("--drive", default=None,
                    help="Shared Drive name (required on a brand-new show "
                         "unless --pick or an existing routing hit supplies one)")
    ap.add_argument("--pick", action="store_true",
                    help="interactively choose/create the drive; overrides --drive")
    season_grp = ap.add_mutually_exclusive_group()
    season_grp.add_argument("--new-season", action="store_true",
                            help="start a new season for a not-yet-known "
                                 "playlist added to an existing show")
    season_grp.add_argument("--same-season", action="store_true",
                            help="append to the current season for a "
                                 "not-yet-known playlist (default)")
    ap.add_argument("--height", type=int, default=1080,
                    help="max video height (0 = best available; default 1080)")
    ap.add_argument("--connections", type=int, default=1,
                    help="per-video download connections. 1 (default) = yt-dlp "
                         "native, which benchmarks fastest when YouTube is not "
                         "throttling. >1 = aria2c multi-connection, which only "
                         "helps when a single connection is being throttled to "
                         "a crawl (try 16 if a download is stuck slow).")
    ap.add_argument("--max-gap", type=int, default=3,
                    help="max episodes downloaded-but-not-yet-uploaded before "
                         "downloading pauses (keeps disk bounded; default 3)")
    ap.add_argument("--stage", default=os.path.expanduser(
                        "~/Downloads/yt-show-stage"),
                    help="local staging directory")
    ap.add_argument("--dry-run", action="store_true",
                    help="print the plan and exit without downloading/uploading")
    ap.add_argument("--plain", action="store_true",
                    help="force plain-text progress (no rich live dashboard)")
    return ap


def main(argv=None):
    args = build_parser().parse_args(argv)

    state = load_state()
    shows = state.setdefault("shows", {})

    plid, ptitle, items = probe_playlist(args.url)
    if not items:
        print("no playable videos")
        return 0

    # Resolve target show: if this playlist already belongs to a show, use it
    # (regardless of --show, which we just note as a mismatch).
    slug = None
    for s_slug, s_rec in shows.items():
        if plid in (s_rec.get("playlists") or {}):
            slug = s_slug
            break
    if slug is None:
        display = args.show or (renamer._clean_show(ptitle)[0] or ptitle)
        slug = renamer._slug(display)
    else:
        display = shows[slug]["display"]
        if args.show and renamer._slug(args.show) != slug:
            print("note: playlist already belongs to show %r (ignoring --show %r)"
                 % (display, args.show))

    show_rec = shows.get(slug)
    if show_rec is None:
        if args.pick:
            drive = pick_drive()
        elif args.drive:
            drive = args.drive
        else:
            try:
                rr = renamer.route(slug, [], renamer.RenameCache(), [])
            except Exception:
                rr = None
            if rr and rr.drive:
                drive = rr.drive
                print("note: routed to drive %r via %s" % (drive, rr.source))
            else:
                sys.exit("new show %r: pass --drive <SharedDriveName> or --pick"
                         % display)
        show_rec = {"display": display, "drive": drive, "episodes": {},
                   "playlists": {}}
        shows[slug] = show_rec
        # Do NOT persist here: --dry-run must not write state, and a real run
        # persists this record naturally on the first verified upload (the
        # consumer's save_state writes the whole state, new show included).
    else:
        display = show_rec["display"]
        drive = (pick_drive() if args.pick else args.drive) or show_rec["drive"]

    mode = "new" if args.new_season else "same"

    # New = not already committed AND not a duplicate id within this playlist
    # (a repeated id would otherwise upload twice, the second commit clobbering
    # the first and orphaning a duplicate file on the drive).
    seen = set()
    new_items = []
    for (vid, vt) in items:
        if vid in show_rec["episodes"] or vid in seen:
            continue
        seen.add(vid)
        new_items.append((vid, vt))
    already = len(items) - len(new_items)
    titles = dict(new_items)
    plan = [{"vid": vid, "season": s, "episode": e, "title": titles[vid]}
            for (vid, s, e) in assign_new_episodes(
                show_rec, plid, [vid for vid, _ in new_items], mode)]

    print("show=%r  drive=%r  playlist=%s  already=%d  new=%d"
         % (display, drive, plid, already, len(plan)))

    # Live drive headroom (from 'todrive du --json', fresher than the GUI's
    # 5-min cache) so the user knows if the playlist will fit before it runs.
    usage = fetch_drive_usage()
    sline = drive_storage_line(drive, usage)
    if sline:
        print(sline)
        u = usage.get(drive)
        if u and u["free"] is not None and u["free"] < 5 * 1000 ** 3:  # < 5 GB
            print("  ! low headroom — a large playlist may not fit. Drivecast "
                  "merges '<Show> Season N' across drives, so you can rerun "
                  "with --pick / --drive on another drive to continue.")
    elif usage:
        print("drive %r: new or empty (no usage reported yet)" % drive)

    rp = renamer.plan_from_sequence(
        [(a["vid"], a["season"], a["episode"], a["title"], ".mp4") for a in plan],
        display)
    if rp.rejected:
        sys.exit("naming contract rejected: " + rp.reason)

    if args.dry_run:
        for a in plan:
            folder = renamer.canonical_folder_name(display, a["season"])
            ep = renamer.synth_episode(display, a["season"], a["episode"], a["title"])
            leaf = renamer.canonical_episode_name(display, ep, ".mp4")
            print("S%02dE%02d  %s/%s  -> %s" %
                 (a["season"], a["episode"], folder, leaf, drive))
        return 0

    if not plan:
        print("up to date (%d already on drive)" % already)
        return 0

    # Per-show exclusive lock: a SECOND yt-show run for the same show would race
    # this one's per-episode save_state (last writer wins -> a commit vanishes)
    # and re-upload the same files. Take it only now -- after the dry-run and
    # up-to-date early exits above, which mutate nothing and so never lock. Held
    # for the whole pipeline via _show_lock; auto-released when this process
    # exits or dies (flock), so a crash never leaves a stuck lock.
    _show_lock = acquire_show_lock(slug)   # noqa: F841 (kept alive to hold lock)
    if _show_lock is None:
        sys.exit("another yt-show run for %r is already active -- wait for it to "
                 "finish (per-show lock)." % display)

    # --- pipeline ------------------------------------------------------
    os.makedirs(args.stage, exist_ok=True)
    if shutil.which("rclone") is None:
        sys.exit("yt-show needs rclone on PATH for uploads "
                 "(brew install rclone)")
    connstr = resolve_connstr(drive)   # fail fast before downloading

    # Crash/interruption recovery, part 1: clear out staged residue for
    # episodes already committed (uploaded), and warn (never delete) about
    # anything else unrecognized. Must run before ui.live() starts -- it
    # prints plain lines, and the rich Live region hasn't opened yet.
    reconcile_stage(args.stage, display, show_rec, plan)

    # Live dashboard: rich when it's installed AND stdout is a real TTY AND the
    # user didn't force --plain; otherwise the terse plain-text UI. (--pick and
    # every input() already happened above, before any Live starts.)
    ui = UI(USE_RICH and sys.stdout.isatty() and not args.plain)
    if not ui.use_rich:
        print("pip install rich for the live dashboard", file=sys.stderr)
    ui.set_header(display, drive)
    u = usage.get(drive) if usage else None
    if u and u["free"] is not None:
        ui.set_capacity(u["free"], u["cap"], u["pct"])
    else:
        ui.set_capacity(None, None, None)
    ui.register_episodes(plan)
    ui.set_counts(len(plan), already, len(items))

    results = {"uploaded": 0, "failed": 0}
    results_lock = threading.Lock()
    q = queue.Queue()   # handoff; the gap semaphore is the real limiter
    # Backpressure: at most --max-gap episodes may be downloaded-but-not-yet-
    # uploaded. The producer acquires a permit BEFORE each download and the
    # uploader releases one after each upload attempt, so when `max_gap`
    # episodes are pending upload the next download blocks until one drains —
    # keeping disk bounded to ~max_gap videos.
    gap = threading.Semaphore(max(1, args.max_gap))
    worker = threading.Thread(
        target=upload_worker,
        args=(q, connstr, display, plid, show_rec, state, results,
              results_lock, ui, gap),
        daemon=True)
    worker.start()

    # SIGTERM (launchd/system shutdown) now takes the identical drain path as
    # Ctrl-C: raise KeyboardInterrupt in the main thread -> the producer loop's
    # except catches it -> sentinel + worker.join() below. Unlike Ctrl-C (which
    # SIGINTs the whole process group, killing an in-flight rclone too),
    # SIGTERM only hits this process, so the in-flight upload actually
    # completes during the drain. try/except guards non-main-thread or exotic
    # platforms where signal.signal() may raise.
    try:
        def _term(signum, frame):
            raise KeyboardInterrupt
        signal.signal(signal.SIGTERM, _term)
    except (ValueError, OSError):
        pass
    with ui.live():
        try:
            for i, a in enumerate(plan, 1):
                key = (a["season"], a["episode"])
                folder = renamer.canonical_folder_name(display, a["season"])
                ep = renamer.synth_episode(display, a["season"], a["episode"],
                                           a["title"])
                stem = renamer.canonical_episode_name(display, ep, "")  # bare stem
                os.makedirs(os.path.join(args.stage, folder), exist_ok=True)
                out_stem = os.path.join(args.stage, folder, stem)
                label = "S%02dE%02d %s" % (a["season"], a["episode"], a["title"])
                # A reused staged file still occupies a pending-upload slot,
                # so acquire BEFORE checking staged_complete_path. Matched by
                # stem+vid (staged_download_stem), never by stem alone -- see
                # the module docstring for why a bare stem can otherwise
                # alias a DIFFERENT video across an interrupted run + resume.
                gap.acquire()   # pause here if max_gap episodes await upload
                got = staged_complete_path(staged_download_stem(out_stem, a["vid"]))
                if got:
                    # Crash-recovery workhorse: a complete-but-uncommitted
                    # file (killed mid-upload, a failed upload, or killed in
                    # the rc==0 -> save_state window) re-uploads directly, with
                    # zero network dependence on the source video still
                    # existing.
                    ui.note("  S%02dE%02d %s (reusing staged file)" %
                           (a["season"], a["episode"], a["title"]))
                else:
                    ui.update_status(key, "downloading")
                    ui.dl_start(label, None)
                    t0 = time.monotonic()
                    got = download_one(a["vid"], out_stem, args.height,
                                       args.connections,
                                       on_progress=lambda st, dn, tot, sp:
                                           ui.dl_advance(dn, tot, sp))
                    ui.dl_finish()
                    if got:
                        elapsed = time.monotonic() - t0
                        try:
                            size = os.path.getsize(got)
                        except OSError:
                            size = 0
                        if elapsed > 0 and size and size / elapsed / 1e6 < 1.5:
                            ui.note("slow download — YouTube may be "
                                    "throttling; try --connections 16")
                if got:
                    q.put((a, got))   # slot released by the uploader when done
                else:
                    gap.release()     # nothing to upload -> free the slot now
                    ui.update_status(key, "failed")
                    with results_lock:
                        results["failed"] += 1
        except KeyboardInterrupt:
            ui.note("interrupted — finishing queued uploads...")
        finally:
            q.put(None)             # sentinel
            worker.join()           # drain: let queued uploads finish + commit

    # tidy empty season dirs left in stage
    for d in glob.glob(os.path.join(args.stage, "*")):
        try:
            os.rmdir(d)
        except OSError:
            pass

    print("uploaded=%d failed=%d" % (results["uploaded"], results["failed"]))
    print("refresh the %r drive in Drivecast to see the show" % drive)
    return 1 if results["failed"] else 0


if __name__ == "__main__":
    sys.exit(main())
